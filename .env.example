# ----------------------------------------------------------------------------
# Environment overrides (OPTIONAL)
# ----------------------------------------------------------------------------
# The app is already wired to the Firebase project "firstmove-ff051" in
# src/lib/firebase.ts, so you normally DO NOT need a .env file at all.
#
# Use this file only if you want to point the app at a DIFFERENT Firebase
# project, or to enable local emulator mode. Copy it to ".env" and fill in the
# values you want to override. (Firebase web keys are public and safe to ship.)
# ----------------------------------------------------------------------------

# --- Override the Firebase project (all optional) ---
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Restrict the admin panel to a single email (defaults to
# firstoptionworldwide@gmail.com, which must match firestore.rules / storage.rules).
VITE_ADMIN_EMAIL=""

# Local demo mode: set to "true" to run entirely against the Firebase Emulator
# Suite (no cloud project or keys needed). `npm run demo` sets this for you.
VITE_USE_EMULATORS="false"
