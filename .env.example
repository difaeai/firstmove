# ----------------------------------------------------------------------------
# Firebase web app configuration
# ----------------------------------------------------------------------------
# 1. Go to https://console.firebase.google.com  ->  create / open your project
# 2. Project settings (gear icon) -> "Your apps" -> Web app (</>) -> register app
# 3. Copy the values from the firebaseConfig object into the variables below
# 4. Save this file as ".env" (remove the ".example")
#
# These values are SAFE to expose in the browser (they are public client keys).
# Access is protected by Firebase Security Rules, not by hiding these keys.
# ----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:abcdef123456"

# Optional: restrict the admin panel to a single email address.
# Leave blank to allow any account you create in Firebase Authentication.
VITE_ADMIN_EMAIL=""

# Local demo mode: set to "true" to run entirely against the Firebase Emulator
# Suite (no cloud project or keys needed). `npm run demo` sets this for you.
# Leave as "false" / unset for production.
VITE_USE_EMULATORS="false"
