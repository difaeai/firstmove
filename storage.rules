rules_version = '2';

// ----------------------------------------------------------------------------
// First Option Worldwide — Cloud Storage security rules
//
// Company-profile attachments for the Trade Delegation form.
//   * Anyone may upload a profile (<= 10 MB, common document/image types),
//     so the public registration form works.
//   * Only a signed-in admin may read the uploaded files.
// ----------------------------------------------------------------------------
service firebase.storage {
  match /b/{bucket}/o {

    match /delegation-profiles/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('application/msword')
          || request.resource.contentType.matches('application/vnd.*')
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('text/.*')
        );
      allow delete: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
