rules_version = '2';

// ----------------------------------------------------------------------------
// First Option Worldwide — Firestore security rules
//
// Model:
//   * The public website may CREATE enquiries and delegation registrations
//     (so the contact / registration forms work) but may NOT read them.
//   * Only a signed-in admin may READ, UPDATE (change status) or DELETE them.
//   * Set VITE_ADMIN_EMAIL in your .env to lock the panel to one address;
//     otherwise any account created in Firebase Authentication is treated
//     as an admin.
// ----------------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Basic shape / anti-spam validation for public submissions.
    function validEnquiry() {
      return request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() < 200
        && request.resource.data.message is string
        && request.resource.data.message.size() < 5000
        && request.resource.data.status == 'new';
    }

    function validDelegation() {
      return request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() < 200
        && request.resource.data.companyName is string
        && request.resource.data.status == 'new';
    }

    match /enquiries/{id} {
      allow create: if validEnquiry();
      allow read, update, delete: if isSignedIn();
    }

    match /delegations/{id} {
      allow create: if validDelegation();
      allow read, update, delete: if isSignedIn();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
